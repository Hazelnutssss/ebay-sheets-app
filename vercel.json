{
  "version": 2,
  "functions": {
    "sheets.js": { "runtime": "@vercel/node" },
    "extract.js": { "runtime": "@vercel/node" }
  },
  "routes": [
    { "src": "/api/sheets", "dest": "/sheets.js" },
    { "src": "/api/extract", "dest": "/extract.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
